{
  "name": "ragit",
  "version": "0.1.0",
  "description": "RAG for git-based AI agent workflows",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ragit": "dist/cli.js"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "docs:dev": "pnpm --filter ./apps/docs... dev",
    "docs:build": "pnpm --filter ./apps/docs... build",
    "docs:check:i18n": "pnpm --filter ./apps/docs... check:i18n",
    "docs:check:search-index": "pnpm --filter ./apps/docs... check:search-index",
    "docs:serve": "pnpm --filter ./apps/docs... start"
  },
  "keywords": [
    "rag",
    "git",
    "cli",
    "agent"
  ],
  "author": "Rhio",
  "license": "ISC",
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "commander": "^14.0.1",
    "fast-glob": "^3.3.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsdown": "^0.21.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  }
}
