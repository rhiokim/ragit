{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "next build && node ./scripts/create-search-alias.mjs",
    "dev": "next dev",
    "start": "serve out",
    "check:commands": "node --import tsx ./scripts/check-command-docs.mjs",
    "check:i18n": "node ./scripts/check-i18n.mjs",
    "check:search-index": "node ./scripts/check-search-index.mjs",
    "types:check": "fumadocs-mdx && next build",
    "postinstall": "fumadocs-mdx"
  },
  "dependencies": {
    "@orama/orama": "^3.1.18",
    "@takumi-rs/image-response": "^0.68.17",
    "fumadocs-core": "16.6.6",
    "fumadocs-mdx": "14.2.8",
    "fumadocs-ui": "16.6.6",
    "lucide-react": "^0.570.0",
    "next": "16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rehype-pretty-code": "^0.14.3",
    "tailwind-merge": "^3.4.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.6",
    "serve": "^14.2.5",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
  }
}
