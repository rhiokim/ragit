7","page_id":"/en/docs/init-guide","tags":[],"type":"text","url":"/en/docs/init-guide#u3-re-running-on-a-partially-initialized-repository","content":"Run `pnpm ragit init`"},"137":{"id":"/en/docs/init-guide-48","page_id":"/en/docs/init-guide","tags":[],"type":"text","url":"/en/docs/init-guide#u3-re-running-on-a-partially-initialized-repository","content":"Existing files are preserved"},"138":{"id":"/en/docs/init-guide-49","page_id":"/en/docs/init-guide","tags":[],"type":"text","url":"/en/docs/init-guide#u3-re-running-on-a-partially-initialized-repository","content":"Missing templates are added"},"139":{"id":"/en/docs/init-guide-50","page_id":"/en/docs/init-guide","tags":[],"type":"text","url":"/en/docs/init-guide#u3-re-running-on-a-partially-initialized-repository","content":"`guide-index.json` is regenerated"},"140":{"id":"/en/docs/init-guide-51","page_id":"/en/docs/init-guide","tags":[],"type":"text","url":"/en/docs/init-guide#u3-re-running-on-a-partially-initialized-repository","content":"The important outcome is that `init` behaves incrementally and can be re-run safely."},"141":{"id":"/en/docs/init-guide-52","page_id":"/en/docs/init-guide","tags":[],"type":"text","url":"/en/docs/init-guide#u4-non-interactive-or-ci-initialization","content":"Use this flow when TTY is unavailable or when automation requires defaults."},"142":{"id":"/en/docs/init-guide-53","page_id":"/en/docs/init-guide","tags":[],"type":"text","url":"/en/docs/init-guide#u4-non-interactive-or-ci-initialization","content":"Run `pnpm ragit init --yes`"},"143":{"id":"/en/docs/init-guide-54","page_id":"/en/docs/init-guide","tags":[],"type":"text","url":"/en/docs/init-guide#u4-non-interactive-or-ci-initialization","content":"If the directory is already a Git repository, initialization proceeds immediately"},"144":{"id":"/en/docs/init-guide-55","page_id":"/en/docs/init-guide","tags":[],"type":"text","url":"/en/docs/init-guide#u4-non-interactive-or-ci-initialization","content":"If it is not a Git repository, `--git-init` is required for automatic initialization"},"145":{"id":"/en/docs/init-guide-56","page_id":"/en/docs/init-guide","tags":[],"type":"text","url":"/en/docs/init-guide#u4-non-interactive-or-ci-initialization","content":"RAGit returns the same guide + zvec-store summary with table or JSON output"},"146":{"id":"/en/docs/init-guide-57","page_id":"/en/docs/init-guide","tags":[],"type":"text","url":"/en/docs/init-guide#u4-non-interactive-or-ci-initialization","content":"The important outcome is that CI can prepare guide/control-plane state and an empty canonical store, but indexing still belongs to a later `ingest` step."},"147":{"id":"/en/docs/memory-model","page_id":"/en/docs/memory-model","type":"page","content":"Memory Model Guide","breadcrumbs":["English"],"tags":[],"url":"/en/docs/memory-model"},"148":{"id":"/en/docs/memory-model-0","page_id":"/en/docs/memory-model","tags":[],"type":"text","url":"/en/docs/memory-model","content":"Understand why RAGit separates working memory from searchable long-term memory"},"149":{"id":"/en/docs/memory-model-1","page_id":"/en/docs/memory-model","type":"heading","tags":[],"url":"/en/docs/memory-model#the-problem","content":"The Problem"},"150":{"id":"/en/docs/memory-model-2","page_id":"/en/docs/memory-model","type":"heading","tags":[],"url":"/en/docs/memory-model#the-mental-model","content":"The Mental Model"},"151":{"id":"/en/docs/memory-model-3","page_id":"/en/docs/memory-model","type":"heading","tags":[],"url":"/en/docs/memory-model#why-two-places-exist","content":"Why Two Places Exist"},"152":{"id":"/en/docs/memory-model-4","page_id":"/en/docs/memory-model","type":"heading","tags":[],"url":"/en/docs/memory-model#command-flow","content":"Command Flow"},"153":{"id":"/en/docs/memory-model-5","page_id":"/en/docs/memory-model","type":"heading","tags":[],"url":"/en/docs/memory-model#how-commands-map","content":"How Commands Map"},"154":{"id":"/en/docs/memory-model-6","page_id":"/en/docs/memory-model","type":"heading","tags":[],"url":"/en/docs/memory-model#a-simple-example","content":"A Simple Example"},"155":{"id":"/en/docs/memory-model-7","page_id":"/en/docs/memory-model","type":"heading","tags":[],"url":"/en/docs/memory-model#common-misunderstandings","content":"Common Misunderstandings"},"156":{"id":"/en/docs/memory-model-8","page_id":"/en/docs/memory-model","type":"heading","tags":[],"url":"/en/docs/memory-model#why-not-search-ragitmemory-directly","content":"Why not search `.ragit/memory/**` directly?"},"157":{"id":"/en/docs/memory-model-9","page_id":"/en/docs/memory-model","type":"heading","tags":[],"url":"/en/docs/memory-model#why-is-promote-separate-from-wrap","content":"Why is `promote` separate from `wrap`?"},"158":{"id":"/en/docs/memory-model-10","page_id":"/en/docs/memory-model","type":"heading","tags":[],"url":"/en/docs/memory-model#when-should-i-promote-something","content":"When should I promote something?"},"159":{"id":"/en/docs/memory-model-11","page_id":"/en/docs/memory-model","type":"heading","tags":[],"url":"/en/docs/memory-model#is-working-memory-the-same-as-a-snapshot","content":"Is working memory the same as a snapshot?"},"160":{"id":"/en/docs/memory-model-12","page_id":"/en/docs/memory-model","type":"heading","tags":[],"url":"/en/docs/memory-model#why-keep-both-working-memory-and-long-term-memory","content":"Why keep both working memory and long-term memory?"},"161":{"id":"/en/docs/memory-model-13","page_id":"/en/docs/memory-model","tags":[],"type":"text","url":"/en/docs/memory-model","content":"RAGit does not treat memory as one giant transcript. It separates memory by purpose so that an agent can resume work without dragging every raw note, tool output, or past conversation back into the prompt."},"162":{"id":"/en/docs/memory-model-14","page_id":"/en/docs/memory-model","tags":[],"type":"text","url":"/en/docs/memory-model#the-problem","content":"Agents do not naturally remember your project the way a teammate does. A raw session log can tell you everything that happened, but it is bad at telling you what matters right now."},"163":{"id":"/en/docs/memory-model-15","page_id":"/en/docs/memory-model","tags":[],"type":"text","url":"/en/docs/memory-model#the-problem","content":"For a user, the real question is simpler:"},"164":{"id":"/en/docs/memory-model-16","page_id":"/en/docs/memory-model","tags":[],"type":"text","url":"/en/docs/memory-model#the-problem","content":"What was I trying to do?"},"165":{"id":"/en/docs/memory-model-17","page_id":"/en/docs/memory-model","tags":[],"type":"text","url":"/en/docs/memory-model#the-problem","content":"Which constraints still matter?"},"166":{"id":"/en/docs/memory-model-18","page_id":"/en/docs/memory-model","tags":[],"type":"text","url":"/en/docs/memory-model#the-problem","content":"What is still open?"},"167":{"id":"/en/docs/memory-model-19","page_id":"/en/docs/memory-model","tags":[],"type":"text","url":"/en/docs/memory-model#the-problem","content":"What knowledge is now stable enough to reuse later?"},"168":{"id":"/en/docs/memory-model-20","page_id":"/en/docs/memory-model","tags":[],"type":"text","url":"/en/docs/memory-model#the-problem","content":"RAGit splits memory so it can answer those questions directly instead of replaying the entire past."},"169":{"id":"/en/docs/memory-model-21","page_id":"/en/docs/memory-model","tags":[],"type":"text","url":"/en/docs/memory-model#the-mental-model","content":"Think about memory in three layers:"},"170":{"id":"/en/docs/memory-model-22","page_id":"/en/docs/memory-model","tags":[],"type":"text","url":"/en/docs/memory-model#the-mental-model","content":"**Short-term memory** is scratch space. It holds temporary notes, rough ideas, and in-progress observations inside a session."},"171":{"id":"/en/docs/memory-model-23","page_id":"/en/docs/memory-model","tags":[],"type":"text","url":"/en/docs/memory-model#the-mental-model","content":"**Working memory** is the active state you want to resume tomorrow. It should tell you the goal, constraints, open loops, and next actions."},"172":{"id":"/en/docs/memory-model-24","page_id":"/en/docs/memory-model","tags":[],"type":"text","url":"/en/docs/memory-model#the-mental-model","content":"**Long-term memory** is reusable project knowledge. It contains things that have become stable enough to search and reuse across future work."},"173":{"id":"/en/docs/memory-model-25","page_id":"/en/docs/memory-model","tags":[],"type":"text","url":"/en/docs/memory-model#the-mental-model","content":"In the current MVP, RAGit emphasizes the second and third layers. Working memory helps you continue a task. Long-term memory helps you find durable knowledge again later. Short-term memory still exists conceptually, but it remains transient scratch space rather than a first-class searchable layer."},"174":{"id":"/en/docs/memory-model-26","page_id":"/en/docs/memory-model","tags":[],"type":"text","url":"/en/docs/memory-model#why-two-places-exist","content":"RAGit uses two places because the project needs two different kinds of memory behavior."},"175":{"id":"/en/docs/memory-model-27","page_id":"/en/docs/memory-model","tags":[],"type":"text","url":"/en/docs/memory-model#why-two-places-exist","content":"`.ragit/memory/**` is the **control plane**. It stores session wraps and current working state. This area is good for resuming work, but it is not meant to be your general searchable knowledge base."},"176":{"id":"/en/docs/memory-model-28","page_id":"/en/docs/memory-model","tags":[],"type":"text","url":"/en/docs/memory-model#why-two-places-exist","content":"`docs/memory/**` is the **searchable corpus**. It stores promoted decisions, glossary entries, and plans as normal documents that can participate in ingest and snapshot-scoped retrieval."},"177":{"id":"/en/docs/memory-model-29","page_id":"/en/docs/memory-model","tags":[],"type":"text","url":"/en/docs/memory-model#why-two-places-exist","content":"This split protects signal quality. Working memory stays focused on “what is active now,” while long-term memory stays focused on “what should remain findable later.”"},"178":{"id":"/en/docs/memory-model-30","page_id":"/en/docs/memory-model","tags":[],"type":"text","url":"/en/docs/memory-model#how-commands-map","content":"`memory wrap` records the state of the work you want to resume. It writes session history and refreshes the current working state."},"179":{"id":"/en/docs/memory-model-31","page_id":"/en/docs/memory-model","tags":[],"type":"text","url":"/en/docs/memory-model#how-commands-map","content":"`memory recall` reconstructs the smallest useful packet for continuing work. It starts from what is active now in working memory and then supplements it with relevant snapshot-scoped retrieval results rather than replaying the full past."},"180":{"id":"/en/docs/memory-model-32","page_id":"/en/docs/memory-model","tags":[],"type":"text","url":"/en/docs/memory-model#how-commands-map","content":"`memory promote` turns stable knowledge into searchable documents. It is how an important conclusion stops being a session detail and becomes project memory. In the current MVP, promoted documents are ingested immediately when `HEAD` is available."},"181":{"id":"/en/docs/memory-model-33","page_id":"/en/docs/memory-model","tags":[],"type":"text","url":"/en/docs/memory-model#how-commands-map","content":"The key idea is that wrap is for continuity, recall is for restoration, and promote is for crystallization."},"182":{"id":"/en/docs/memory-model-34","page_id":"/en/docs/memory-model","tags":[],"type":"text","url":"/en/docs/memory-model#a-simple-example","content":"Imagine you stop work on an auth migration at the end of the day."},"183":{"id":"/en/docs/memory-model-35","page_id":"/en/docs/memory-model","tags":[],"type":"text","url":"/en/docs/memory-model#a-simple-example","content":"You use `memory wrap` to save the current goal, the rule that snapshot contracts must stay intact, the open loop about token refresh, and the next action for tomorrow. That state lives in `.ragit/memory/**`."},"184":{"id":"/en/docs/memory-model-36","page_id":"/en/docs/memory-model","tags":[],"type":"text","url":"/en/docs/memory-model#a-simple-example","content":"The next morning, you do not want to reread every note. You use `memory recall`. RAGit pulls the current working state and combines it with relevant retrieved knowledge, such as earlier decisions about auth boundaries or plans stored in the repository. You get a recall packet that tells you where to restart."},"185":{"id":"/en/docs/memory-model-37","page_id":"/en/docs/memory-model","tags":[],"type":"text","url":"/en/docs/memory-model#a-simple-example","content":"Later, once a rule becomes stable, such as “refresh token handling must remain outside snapshot mutation,” you use `memory promote`. That rule becomes a durable document in `docs/memory/**`, where future sessions can search it like any other project knowledge."},"186":{"id":"/en/docs/memory-model-38","page_id":"/en/docs/memory-model","tags":[],"type":"text","url":"/en/docs/memory-model#why-not-search-ragitmemory-directly","content":"Because working state changes often and exists to help you resume active work. It is operational state, not automatically durable knowledge."},"187":{"id":"/en/docs/memory-model-39","page_id":"/en/docs/memory-model","tags":[],"type":"text","url":"/en/docs/memory-model#why-is-promote-separate-from-wrap","content":"Because not every session note deserves to become long-term memory. Promotion is the deliberate step that keeps the searchable corpus clean."},"188":{"id":"/en/docs/memory-model-40","page_id":"/en/docs/memory-model","tags":[],"type":"text","url":"/en/docs/memory-model#when-should-i-promote-something","content":"Promote it when you expect a future session to benefit from finding it without reopening the original session history. In the current MVP, that usually means a stable decision, a reusable term, or a plan worth searching later."},"189":{"id":"/en/docs/memory-model-41","page_id":"/en/docs/memory-model","tags":[],"type":"text","url":"/en/docs/memory-model#is-working-memory-the-same-as-a-snapshot","content":"No. A snapshot answers, “What knowledge is searchable for this commit?” Working memory answers, “What am I actively trying to continue right now?”"},"190":{"id":"/en/docs/memory-model-42","page_id":"/en/docs/memory-model","tags":[],"type":"text","url":"/en/docs/memory-model#why-keep-both-working-memory-and-long-term-memory","content":"Because they solve different recovery problems. Working memory restores momentum. Long-term memory restores durable knowledge."},"191":{"id":"/en/docs/quickstart","page_id":"/en/docs/quickstart","type":"page","content":"Quickstart","breadcrumbs":["English"],"tags":[],"url":"/en/docs/quickstart"},"192":{"id":"/en/docs/quickstart-0","page_id":"/en/docs/quickstart","tags":[],"type":"text","url":"/en/docs/quickstart","content":"Get started with RAGit and docs workflow"},"193":{"id":"/en/docs/quickstart-1","page_id":"/en/docs/quickstart","type":"heading","tags":[],"url":"/en/docs/quickstart#requirements","content":"Requirements"},"194":{"id":"/en/docs/quickstart-2","page_id":"/en/docs/quickstart","type":"heading","tags":[],"url":"/en/docs/quickstart#install","content":"Install"},"195":{"id":"/en/docs/quickstart-3","page_id":"/en/docs/quickstart","type":"heading","tags":[],"url":"/en/docs/quickstart#initialize-ragit","content":"Initialize RAGit"},"196":{"id":"/en/docs/quickstart-4","page_id":"/en/docs/quickstart","type":"heading","tags":[],"url":"/en/docs/quickstart#run-docs-locally","content":"Run docs locally"},"197":{"id":"/en/docs/quickstart-5","page_id":"/en/docs/quickstart","tags":[],"type":"text","url":"/en/docs/quickstart#requirements","content":"Node.js 20+"},"198":{"id":"/en/docs/quickstart-6","page_id":"/en/docs/quickstart","tags":[],"type":"text","url":"/en/docs/quickstart#requirements","content":"pnpm 10+"},"199":{"id":"/en/docs/quickstart-7","page_id":"/en/docs/quickstart","tags":[],"type":"text","url":"/en/docs/quickstart#req